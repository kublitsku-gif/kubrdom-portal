# HTML всегда перепроверяется (чтобы телефоны не держали старую версию в кэше)
/*
  Cache-Control: public, max-age=0, must-revalidate
  # Защита от кликджекинга: админку нельзя встроить в чужой <iframe>
  X-Frame-Options: DENY
  Content-Security-Policy: frame-ancestors 'none'
  # Не угадывать MIME-тип (защита от sniffing-атак)
  X-Content-Type-Options: nosniff
  # Не утекать URL панели в Referer на сторонние сайты
  Referrer-Policy: strict-origin-when-cross-origin
  # Только HTTPS (год), защита от downgrade/SSL-strip
  Strict-Transport-Security: max-age=31536000; includeSubDomains
